{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/agi-for-my-llama/agentscan/main/.agentscan.schema.json",
  "title": "AgentScan config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "fail_on": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "ignore_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "ignore_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "baseline": {
      "type": "string",
      "minLength": 1
    },
    "max_file_bytes": {
      "type": "integer",
      "minimum": 1
    }
  }
}
